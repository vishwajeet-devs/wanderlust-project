<style>
  .search-btn {
    background-color: #fcbec2;
    color: #c9202b;
    border-radius: 25px;
    padding: 0 1rem 0 1rem;
  }
  .search-btn:hover {
    background-color: #fe424d;
    color: #fff;
  }
  .search-btn i {
    display: inline;
    margin-right: 0.5rem;
  }
  .search-input {
    border-radius: 25px;
    padding: 0.5rem 3rem 0.5rem 3rem;
    font-size: 1rem;
  }
  .active-link {
    background-color: #fcbec2;
    color: #c9202b !important;
    border-radius: 999px;
    padding: 2px 6px;
    transition: all 0.2s ease;
  }
  .nav-link {
    padding: 8px 16px;
    border-radius: 999px;
    color: #333;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .nav-link:hover {
    background-color: #f2f2f2;
  }

  /* ── Mobile only — laptop is completely unchanged ── */
  @media (max-width: 767.98px) {
    /* Each nav group stacks and takes full width */
    #navbarNavAltMarkup .navbar-nav {
      width: 100%;
      margin-left: 0 !important;
    }

    /* Search bar full width */
    .navbar-search-form {
      width: 100%;
      margin: 0.3rem 0;
    }
    .search-input {
      flex: 1;
      min-width: 0;
      padding: 0.45rem 1rem;
      font-size: 0.9rem;
    }

    /* Explore row stays horizontal */
    .nav-explore {
      flex-direction: row;
    }

    /* Right links: wrap into a tidy row */
    .nav-actions {
      flex-direction: row !important;
      flex-wrap: wrap;
      gap: 0.2rem;
      padding-bottom: 0.4rem;
    }
    .nav-actions .nav-link {
      padding: 5px 10px;
      font-size: 0.88rem;
    }
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top mb-3">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-brands fa-airbnb"></i></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <!-- Explore -->
      <div class="navbar-nav nav-explore">
        <a class="nav-link <%= currPath.includes('/listings') ? 'active-link' : '' %>" href="/listings">Explore</a>
      </div>

      <!-- Search -->
      <div class="navbar-nav ms-auto">
        <form class="d-flex navbar-search-form" role="search" method="get" action="<%= currPath.includes('/my') ? '/listings/my' : '/listings' %>">
          <input class="form-control me-2 search-input" type="search" placeholder="Search destinations" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>"/>
          <button class="btn search-btn" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>Search
          </button>
        </form>
      </div>

      <!-- Right links -->
      <div class="navbar-nav ms-auto nav-actions">
        <a class="nav-link <%= currPath.includes('/listings/new') ? 'active-link' : '' %>" href="/listings/new">Airbnb your home</a>
        <% if(!currUser) { %>
          <a class="nav-link <%= currPath.includes('/signup') ? 'active-link' : '' %>" href="/signup"><b>Sign up</b></a>
          <a class="nav-link <%= currPath.includes('/login') ? 'active-link' : '' %>" href="/login"><b>Log in</b></a>
        <% } if(currUser) { %>
          <a class="nav-link <%= currPath.includes('/listings/my') ? 'active-link' : '' %>" href="/listings/my">My home</a>
          <a class="nav-link" href="/logout"><b>Log out</b></a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
