<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h3>Edit your Listing</h3>
    <form method="post" action="/listings/<%=listing._id%>?_method=PUT">
        <input name="listing[title]" type="text" value="<%= listing.title %>">
        <br><br>
        <textarea name="listing[description]" type="text"><%= listing.description %></textarea>
        <br><br>
        <input name="listing[image]" placeholder="enter image URL/Link" type="text">
        <br><br>
        <input name="listing[price]" type="number" value="<%= listing.price %>">
        <br><br>
        <input name="listing[country]" type="text" value="<%= listing.country %>">
        <br><br>
        <input name="listing[location]" value="<%= listing.location %>" type="text">
        <br><br>
        <button>Edit</button>
    </form>
</body>
</html>