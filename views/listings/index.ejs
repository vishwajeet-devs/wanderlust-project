<%- layout("/layouts/boilerplate") %>

    <body>
        <style>
            #filters {
                display: flex;
                flex-wrap: wrap;
                align-items: center;
                margin-bottom: 1rem;
            }

            .filter {
                text-align: center;
                margin-right: 2rem;
                opacity: 0.5;
            }

            .filter:hover {
                opacity: 1;
                cursor: pointer;
            }

            #filters a {
                text-decoration: none;
                color: inherit;
            }

            .tax-info {
                display: none;
                font-size: 0.7rem;
                color: rgb(177, 176, 176);
            }

            .tax-toggle {
                border: 1px solid black;
                border-radius: 1rem;
                height: 2.8rem;
                padding: 0.5rem;
                display: flex;
                align-items: center;
                margin-top: -1rem;
                margin-left: 3.2rem;
            }
        </style>

        <div id="filters">
            <div class="filter">
                <a href="/listings">
                    <div><i class="fa-solid fa-fire"></i></div>
                    <p>All</p>
                </a>
            </div>

            <div class="filter">
                <a href="/listings?cat=room">
                    <div><i class="fa-solid fa-bed"></i></div>
                    <p>Room</p>
                </a>
            </div>

            <div class="filter">
                <a href="/listings?cat=iconicCities">
                    <div><i class="fa-solid fa-mountain-city"></i></div>
                    <p>Iconic Cities</p>
                </a>
            </div>

            <div class="filter">
                <a href="/listings?cat=mountains">
                    <div><i class="fa-solid fa-mountain"></i></div>
                    <p>Mountains</p>
                </a>
            </div>

            <div class="filter">
                <a href="/listings?cat=castles">
                    <div><i class="fa-brands fa-fort-awesome"></i></div>
                    <p>Castles</p>
                </a>
            </div>

            <div class="filter">
                <a href="/listings?cat=amazingpools">
                    <div><i class="fa-solid fa-person-swimming"></i></div>
                    <p>Amazing pools</p>
                </a>
            </div>

            <div class="filter">
                <a href="/listings?cat=camping">
                    <div><i class="fa-solid fa-campground"></i></div>
                    <p>Camping</p>
                </a>
            </div>

            <div class="filter">
                <a href="/listings?cat=farms">
                    <div><i class="fa-solid fa-cow"></i></div>
                    <p>Farms</p>
                </a>
            </div>

            <div class="filter">
                <a href="/listings?cat=arctic">
                    <div><i class="fa-solid fa-snowflake"></i></div>
                    <p>Arctic</p>
                </a>
            </div>

            <div class="filter">
                <a href="/listings?cat=domes">
                    <div><i class="fa-solid fa-igloo"></i></div>
                    <p>Domes</p>
                </a>
            </div>

            <div class="filter">
                <a href="/listings?cat=boats">
                    <div><i class="fa-solid fa-sailboat"></i></div>
                    <p>Boats</p>
                </a>
            </div>

            <div class="tax-toggle">
                <div class="form-check-reverse form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                    <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
                </div>
            </div>
        </div>

        <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1">
            <% if(allListings.length==0) { %>
                <div class="d-flex justify-content-center align-items-center w-100" style="height: 60vh;">
                    <h1 style="color: rgb(165, 165, 165)">Listing not found !</h1>
                </div>          
            <% } %>
            <% for(let listing of allListings) { %>
                <a href="/listings/<%=listing._id%>" class="listing-link">
                    <div class="card col listing-card" style="width: 18rem;">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_img"
                            style="height: 10rem">
                        <div class="card-img-overlay"></div>
                        <div class="card-body">
                            <p class="card-text">
                                <b><%= listing.title %></b><br>
                                &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                                <b class="tax-info"> &nbsp; &nbsp;+18% GST </b>
                            </p>
                        </div>
                    </div>
                </a>
                <% } %>
        </div>
    </body>

    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click", () => {
            let taxInfo = document.getElementsByClassName("tax-info");
            for(info of taxInfo){
                if(info.style.display != "inline") info.style.display = "inline";
                else info.style.display = "none";
            }
        })

        const input = document.querySelector(".search-input");

        input.addEventListener("input", () => {
            if (input.value === "") {
                input.form.submit();
            }
        });

    </script>