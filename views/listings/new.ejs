<%- layout("/layouts/boilerplate") %>   
<body>
    <div class="row">
        <div class="col-8 offset-2">
            <h3>Create a new Listing</h3>
            <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input name="listing[title]" placeholder="enter title" type="text" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea name="listing[description]" placeholder="enter description" type="text" required class="form-control"></textarea>
                    <div class="invalid-feedback">Please enter a short description</div>
                </div>
                <!-- <div class="mb-3">
                    <label class="form-label">Image link</label>
                    <input name="listing[image]" placeholder="enter image URL/Link" type="text" class="form-control">
                </div> -->
                <div class="mb-3">
                    <label class="form-label">Upload Image</label>
                    <input name="listing[image]" type="file" class="form-control" required>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label class="form-label">Price</label>
                        <input name="listing[price]" placeholder="enter price" required class="form-control">
                        <div class="invalid-feedback">Price should be valid</div>
                    </div>
                    <div class="mb-3 col-md-8">
                        <label class="form-label">Country</label>
                        <input name="listing[country]" placeholder="enter country" type="text" required class="form-control">
                        <div class="invalid-feedback">Country name shold be valid</div>
                    </div>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-8">
                        <label class="form-label">Location</label>
                        <input name="listing[location]" placeholder="enter location" type="text" required class="form-control">
                        <div class="invalid-feedback">Location should be valid</div>
                    </div>
                    <div class="mb-3 col-md-4">
                        <label class="form-label">Select Category</label>
                        <select name="listing[category]" class="form-select" required>
                            <option value="">Select Category</option>
                            <option value="room">Room</option>
                            <option value="iconicCities">Iconic Cities</option>
                            <option value="mountains">Mountains</option>
                            <option value="castles">Castles</option>
                            <option value="amazingpools">Amazing pools</option>
                            <option value="camping">Camping</option>
                            <option value="farms">Farms</option>
                            <option value="arctic">Arctic</option>
                            <option value="domes">Domes</option>
                            <option value="boats">Boats</option>
                        </select>
                    </div>
                </div>
                
                <button class="btn btn-dark add-btn mb-3">Add</button>
            </div>
        </div>
    </form>
</body>